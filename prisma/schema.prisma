generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(CLIENT)
  phone     String?
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  Hewan     Hewan[]  @relation("OwnerHewan")
  appointmentsAsPelanggan Appointment[] @relation("PelangganAppointments")
  appointmentsAsDokter Appointment[] @relation("DokterAppointments")
  rekamMedis RekamMedis[] @relation("DokterRekamMedis")
  jadwal JadwalDokter[] @relation("DokterJadwal")
  sentMessages Pesan[] @relation("SentMessages")
  receivedMessages Pesan[] @relation("ReceivedMessages")
  inventoryMovements InventoryMovement[]
  notifikasi Notifikasi[]
  passwordResets PasswordReset[]
  invoices Invoice[] @relation("CustomerInvoices")
  approvedInvoices Invoice[] @relation("ApprovedInvoices")
  printedInvoices Invoice[] @relation("PrintedInvoices")
}

model Hewan {
  id            String   @id @default(cuid())
  nama          String
  jenis         Jenis
  ras           String?
  tanggalLahir  DateTime?
  beratBadan    Float?
  foto          String?
  catatanKhusus String?
  pelangganId   String
  pelanggan     User     @relation(fields: [pelangganId], references: [id], name: "OwnerHewan", onDelete: Cascade)
  Monitoring    MonitoringHarian[]
  RekamMedis    RekamMedis[]
  appointments  Appointment[] @relation("HewanAppointments")
  invoices      Invoice[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([pelangganId])
}

model MonitoringHarian {
  id            String   @id @default(cuid())
  hewanId       String
  hewan         Hewan    @relation(fields: [hewanId], references: [id], onDelete: Cascade)
  tanggal       DateTime
  beratBadan    Float?
  suhu          Float?
  nafsuMakan    NafsuMakan
  aktivitas     Aktivitas
  catatanGejala String?
  createdAt     DateTime @default(now())

  @@index([hewanId])
}

model Appointment {
  id          String   @id @default(cuid())
  pelangganId String
  pelanggan   User     @relation("PelangganAppointments", fields: [pelangganId], references: [id], onDelete: Cascade)
  hewanId     String
  hewan       Hewan    @relation("HewanAppointments", fields: [hewanId], references: [id], onDelete: Cascade)
  dokterId    String?
  dokter      User?    @relation("DokterAppointments", fields: [dokterId], references: [id], onDelete: SetNull)
  tanggal     DateTime
  waktu       String
  jenis       JenisLayanan
  keluhan     String?
  status      AppointmentStatus @default(MENUNGGU)
  catatanAdmin String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  RekamMedis   RekamMedis?
  messages     Pesan[]  @relation("AppointmentMessages")

  @@index([pelangganId])
  @@index([hewanId])
  @@index([dokterId])
}

model RekamMedis {
  id              String   @id @default(cuid())
  appointmentId   String   @unique
  appointment     Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  hewanId         String
  hewan           Hewan    @relation(fields: [hewanId], references: [id], onDelete: Cascade)
  dokterId        String
  dokter          User     @relation("DokterRekamMedis", fields: [dokterId], references: [id], onDelete: Cascade)
  tanggalPeriksa  DateTime
  keluhan         String?
  diagnosis       String?
  tindakan        String?
  resep           String?
  obat            String?
  perawatan       String?
  dosis           String?
  catatanPerawatan String?
  catatanDokter   String?
  lampiran        String[] @default([])
  progress        TreatmentProgress[]
  createdAt       DateTime @default(now())

  @@index([appointmentId])
  @@index([hewanId])
  @@index([dokterId])
}

model TreatmentProgress {
  id           String   @id @default(cuid())
  rekamMedisId String
  rekamMedis   RekamMedis @relation(fields: [rekamMedisId], references: [id], onDelete: Cascade)
  tanggal      DateTime @default(now())
  kondisi      String
  progress     String
  catatan      String?
  createdAt    DateTime @default(now())

  @@index([rekamMedisId])
}

model JadwalDokter {
  id         String   @id @default(cuid())
  dokterId   String
  dokter     User     @relation("DokterJadwal", fields: [dokterId], references: [id], onDelete: Cascade)
  hari       Hari
  jamMulai   String
  jamSelesai String
  isAktif    Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@index([dokterId])
}

model Inventory {
  id                String       @id @default(cuid())
  namaItem          String
  kategori          Kategori
  stok              Int
  satuan            String
  harga             Float
  stokMinimal       Int
  lastManualCheckAt DateTime?
  categoryId        String?
  category          ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  movements         InventoryMovement[]
  items             InvoiceItem[]
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([categoryId])
}

model ProductCategory {
  id          String      @id @default(cuid())
  name        String      @unique
  description String?
  inventories Inventory[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model InventoryMovement {
  id          String                @id @default(cuid())
  inventoryId String
  inventory   Inventory             @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  type        InventoryMovementType
  quantity    Int
  beforeStock Int
  afterStock  Int
  note        String?
  createdAt   DateTime              @default(now())

  @@index([inventoryId])
  @@index([userId])
}

model Pesan {
  id           String   @id @default(cuid())
  senderId     String
  sender       User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId   String
  receiver     User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  appointmentId String?
  appointment  Appointment? @relation("AppointmentMessages", fields: [appointmentId], references: [id], onDelete: Cascade)
  isi          String
  isRead       Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([senderId])
  @@index([receiverId])
  @@index([appointmentId])
}

model Notifikasi {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  judul     String
  isi       String
  tipe      NotifikasiTipe
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}


model KontenLanding {
  id        String   @id @default(cuid())
  section   String
  key       String
  value     String
  updatedAt DateTime @updatedAt
}

model Artikel {
  id         String   @id @default(cuid())
  judul      String
  slug       String   @unique
  konten     String
  thumbnail  String?
  isPublished Boolean @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model PasswordReset {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String
  expiresAt  DateTime
  used       Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([userId])
}

model Invoice {
  id            String       @id @default(cuid())
  invoiceNumber String       @unique
  customerId    String
  customer      User         @relation("CustomerInvoices", fields: [customerId], references: [id], onDelete: Cascade)
  hewanId       String?
  hewan         Hewan?       @relation(fields: [hewanId], references: [id], onDelete: SetNull)
  total         Float        @default(0)
  status        InvoiceStatus @default(DRAFT)
  approvedById  String?
  approvedBy    User?        @relation("ApprovedInvoices", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt    DateTime?
  printedById   String?
  printedBy     User?        @relation("PrintedInvoices", fields: [printedById], references: [id], onDelete: SetNull)
  printedAt     DateTime?
  voidReason    String?
  items         InvoiceItem[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([status])
  @@index([customerId])
  @@index([hewanId])
  @@index([approvedById])
  @@index([printedById])
}

model InvoiceItem {
  id          String    @id @default(cuid())
  invoiceId   String
  invoice     Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  inventoryId String?
  inventory   Inventory? @relation(fields: [inventoryId], references: [id], onDelete: SetNull)
  namaItem    String
  quantity    Int
  unitPrice   Float
  subTotal    Float

  @@index([invoiceId])
  @@index([inventoryId])
}

enum InvoiceStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  PRINTED
  PAID
  VOID
}

enum Role {
  ADMIN
  STAFF
  DOKTER
  CLIENT
}

enum Jenis {
  KUCING
  ANJING
  BURUNG
  KELINCI
  LAINNYA
}

enum NafsuMakan {
  BAIK
  SEDANG
  BURUK
}

enum Aktivitas {
  AKTIF
  NORMAL
  LESU
}

enum JenisLayanan {
  PEMERIKSAAN
  VAKSINASI
  BEDAH
  GROOMING
  DENTAL
  RAWAT_INAP
  TELEMEDICINE
  HOME_VISIT
}

enum AppointmentStatus {
  MENUNGGU
  DIKONFIRMASI
  SELESAI
  DIBATALKAN
}

enum Hari {
  SENIN
  SELASA
  RABU
  KAMIS
  JUMAT
  SABTU
  MINGGU
}

enum Kategori {
  OBAT
  ALAT
  KONSUMABLE
}

enum InventoryMovementType {
  SALE
  MANUAL_ADJUSTMENT
  RESTOCK
  RETURN
}

enum NotifikasiTipe {
  INFO
  PERINGATAN
  SUKSES
}
